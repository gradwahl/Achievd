{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Achievd",
  "version": "0.1.0",
  "identifier": "com.achievd.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../.desktop-build/current-web"
  },
  "app": {
    "windows": [
      {
        "title": "Achievd",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["../build/icon.ico"]
  }
}
