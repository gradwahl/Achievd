generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VisibilityState {
  PUBLIC
  PRIVATE
  FRIENDS_ONLY
  UNKNOWN
}

enum SyncType {
  PROFILE
  FULL
  GAME
  RARITY
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILURE
}

enum PinPriority {
  LOW
  MEDIUM
  HIGH
}

enum PinState {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model User {
  id                 String              @id @default(cuid())
  steamId            String              @unique
  preferences        Json                @default("{}")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lastLoginAt        DateTime?
  steamProfile       SteamProfile?
  games              UserGame[]
  achievements       UserAchievement[]
  pinnedAchievements PinnedAchievement[]
  syncRecords        SyncRecord[]

  @@index([steamId])
}

model SteamProfile {
  id              String          @id @default(cuid())
  userId          String          @unique
  displayName     String
  avatarSmallUrl  String?
  avatarMediumUrl String?
  avatarFullUrl   String?
  profileUrl      String?
  visibilityState VisibilityState @default(UNKNOWN)
  lastSyncedAt    DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id                     String        @id @default(cuid())
  steamAppId             Int           @unique
  name                   String
  genres                 String[]      @default([])
  developers             String[]      @default([])
  publishers             String[]      @default([])
  capsuleImageUrl        String?
  headerImageUrl         String?
  totalKnownAchievements Int           @default(0)
  lastSchemaSyncedAt     DateTime?
  hasPaidDlc             Boolean       @default(false)
  fastestCompletionTime  Int?
  medianCompletionTime   Int?
  steamHuntersSyncedAt   DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  achievements           Achievement[]
  userGames              UserGame[]

  @@index([name])
}

model UserGame {
  id                       String    @id @default(cuid())
  userId                   String
  gameId                   String
  playtimeMinutes          Int?
  unlockedAchievementCount Int       @default(0)
  totalAchievementCount    Int       @default(0)
  completionPercentage     Float     @default(0)
  perfected                Boolean   @default(false)
  hidden                   Boolean   @default(false)
  customBoxArtUrl          String?
  customBannerUrl          String?
  lastPlayedAt             DateTime?
  lastSyncedAt             DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  game                     Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId, hidden, completionPercentage])
  @@index([userId, hidden, updatedAt])
  @@index([userId, perfected])
  @@index([userId, completionPercentage])
  @@index([userId, lastPlayedAt])
}

model Achievement {
  id                           String              @id @default(cuid())
  gameId                       String
  apiName                      String
  displayName                  String
  description                  String?
  hidden                       Boolean             @default(false)
  lockedIconUrl                String?
  unlockedIconUrl              String?
  globalCompletionPercentage   Float?
  globalCompletionLastSyncedAt DateTime?
  achievementGroupName         String?
  achievementGroupSort         Int                 @default(0)
  achievementGroupSteamAppId   Int?
  achievementGroupLastSyncedAt DateTime?
  obtainability                Int                 @default(0)
  obtainabilityLastSyncedAt    DateTime?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  game                         Game                @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userAchievements             UserAchievement[]
  pinnedAchievements           PinnedAchievement[]

  @@unique([gameId, apiName])
  @@index([gameId, hidden])
  @@index([gameId, achievementGroupSort])
  @@index([gameId, obtainability])
  @@index([globalCompletionPercentage])
}

model UserAchievement {
  id              String      @id @default(cuid())
  userId          String
  achievementId   String
  unlocked        Boolean     @default(false)
  unlockedAt      DateTime?
  firstObservedAt DateTime    @default(now())
  lastObservedAt  DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, unlocked])
  @@index([userId, unlockedAt])
}

model PinnedAchievement {
  id                 String      @id @default(cuid())
  userId             String
  achievementId      String
  notes              String      @default("")
  manualProgressText String      @default("")
  priority           PinPriority @default(MEDIUM)
  state              PinState    @default(ACTIVE)
  position           Int         @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement        Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, state, position])
}

model SyncRecord {
  id                  String     @id @default(cuid())
  userId              String
  syncType            SyncType
  startedAt           DateTime   @default(now())
  completedAt         DateTime?
  status              SyncStatus @default(RUNNING)
  errorSummary        String?
  gamesUpdated        Int        @default(0)
  achievementsUpdated Int        @default(0)
  user                User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, syncType, startedAt])
  @@index([userId, status])
}
