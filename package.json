{
  "name": "achievd",
  "version": "0.1.0",
  "description": "Standalone Steam achievement-tracking desktop app.",
  "author": "Achievd",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "main": "desktop/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node desktop/prepare-next.cjs",
    "desktop:dev": "node desktop/dev.cjs",
    "desktop:build": "pnpm build && electron-builder --dir",
    "desktop:package": "pnpm build && electron-builder --win nsis",
    "desktop:portable": "pnpm build && electron-builder --win portable",
    "start": "node --max-old-space-size=1024 desktop/start-next.cjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit tests/components",
    "test:e2e": "playwright test",
    "postgres:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-postgres.ps1",
    "postgres:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-postgres.ps1",
    "db:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate"
  },
  "build": {
    "appId": "com.achievd.desktop",
    "productName": "Achievd",
    "directories": {
      "output": "dist"
    },
    "afterPack": "desktop/after-pack.cjs",
    "files": [
      "desktop/main.cjs",
      "desktop/after-pack.cjs",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName} ${version}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName} Setup ${version}.${ext}",
      "oneClick": false,
      "perMachine": false
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": ".desktop-build/next",
        "to": "next",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@swc/helpers": "^0.5.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "next": "16.2.11",
    "pg": "^8.22.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "recharts": "^3.10.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.4",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.2",
    "prettier": "^3.9.6",
    "prisma": "^7.9.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
